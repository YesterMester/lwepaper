+// Parent-aware transform resolution, mirroring CImage::resolveTransform (kept
+// local to avoid a cross-class dependency). Wallpaper Engine positions child
+// layers RELATIVE to their parent "window"/group containers; a text layer's
+// own origin is an offset within that parent. Without folding in the parent
+// chain, a clock/date layer — e.g. origin (-160, 12) inside "World Clock
+// Window" at (653, 293) — lands far off-screen, which is exactly why the
+// Pixels dashboard panels (clocks, calendar, world time) rendered blank.
+struct ResolvedXf {
+    glm::vec3 origin;
+    glm::vec3 scale;
+    float angle;
+};
+
+glm::vec2 rotateVec2Xf (const glm::vec2& v, float a) {
+    const float c = std::cos (a);
+    const float s = std::sin (a);
+    return { v.x * c - v.y * s, v.x * s + v.y * c };
+}
+
+ResolvedXf localXf (const WallpaperEngine::Data::Model::Object& object) {
+    using namespace WallpaperEngine::Data::Model;
+    glm::vec3 origin = object.origin->value->getVec3 ();
+    glm::vec3 scale = glm::vec3 (1.0f);
+    float angle = 0.0f;
+
+    if (object.is<Image> ()) {
+        const auto* image = object.as<Image> ();
+        scale = image->scale->value->getVec3 ();
+        angle = image->angles->value->getVec3 ().z;
+    } else if (object.is<Text> ()) {
+        const auto* text = object.as<Text> ();
+        scale = text->scale->value->getVec3 ();
+    } else {
+        scale = object.groupScale->value->getVec3 ();
+        angle = object.groupAngles->value->getVec3 ().z;
+    }
+
+    return { origin, scale, angle };
+}
+
+ResolvedXf resolveXf (
+    WallpaperEngine::Render::Wallpapers::CScene& scene, const WallpaperEngine::Data::Model::Object& object
+) {
+    using WallpaperEngine::Data::Model::Object;
+    constexpr int kMaxParentDepth = 32;
+
+    const Object* chain[kMaxParentDepth + 1];
+    int count = 0;
+    const Object* current = &object;
+    chain[count++] = current;
+
+    while (current->parent.has_value ()) {
+        if (count > kMaxParentDepth) {
+            break;
+        }
+        const auto* parentObject = scene.getObject (current->parent.value ());
+        if (parentObject == nullptr) {
+            break;
+        }
+        current = &parentObject->getObject ();
+        chain[count++] = current;
+    }
+
+    ResolvedXf resolved = localXf (*chain[count - 1]);
+    for (int i = count - 2; i >= 0; --i) {
+        ResolvedXf local = localXf (*chain[i]);
+        const glm::vec2 offset
+            = rotateVec2Xf ({ local.origin.x * resolved.scale.x, local.origin.y * resolved.scale.y }, resolved.angle);
+        local.origin.x = resolved.origin.x + offset.x;
+        local.origin.y = resolved.origin.y + offset.y;
+        local.origin.z = resolved.origin.z + local.origin.z * resolved.scale.z;
+        resolved = { local.origin, local.scale * resolved.scale, local.angle + resolved.angle };
+    }
+
+    return resolved;
+}
