+void ScriptEngine::registerStaticLayerText (const std::string& layerName, const std::string& text) {
+    if (!this->m_context || layerName.empty ()) {
+	return;
+    }
+
+    this->ensureLayerRegistry ();
+
+    JSContext* ctx = this->m_context;
+    JSValue globalObj = JS_GetGlobalObject (ctx);
+    JSValue byName = JS_GetPropertyStr (ctx, globalObj, "__textLayersByName");
+
+    if (!JS_IsUndefined (byName) && !JS_IsNull (byName)) {
+	JSValue holder = JS_NewObject (ctx);
+	JS_SetPropertyStr (ctx, holder, "text", JS_NewString (ctx, text.c_str ()));
+	JS_SetPropertyStr (ctx, byName, layerName.c_str (), holder);
+    }
+
+    JS_FreeValue (ctx, byName);
+    JS_FreeValue (ctx, globalObj);
+}
